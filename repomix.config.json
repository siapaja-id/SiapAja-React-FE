{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 52428800
  },
  "output": {
    "filePath": "dev-docs/repomix.md",
    "style": "markdown",
    "parsableStyle": true,
    "fileSummary": false,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "compress": false,
    "topFilesLength": 5,
    "showLineNumbers": false,
    "truncateBase64": false,
    "copyToClipboard": true,
    "includeFullDirectoryStructure": false,
    "tokenCountTree": false,
    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 100,
      "includeDiffs": false,
      "includeLogs": false,
      "includeLogsCount": 50
    }
  },
  "include": 

  ["src/App.tsx", "src/index.css", "src/store/app.slice.ts", "src/store/main.store.ts", "src/shared/types/store.types.ts", "src/shared/types/auth.types.ts", "src/shared/types/wallet.types.ts (new)", "src/shared/constants/domain.constant.tsx", "src/shared/ui/SharedUI.Component.tsx", "src/features/kanban/routes.tsx", "src/features/kanban/components/FloatingSidebar.tsx", "src/features/profile/pages/Profile.Page.tsx", "src/features/gigs/pages/Payment.Page.tsx", "src/features/gigs/components/PaymentOption.Component.tsx", "src/features/wallet/pages/Wallet.Page.tsx (new)", "src/features/wallet/components/BalanceCard.Component.tsx (new)", "src/features/wallet/components/TransactionList.Component.tsx (new)", "src/features/wallet/components/TransactionItem.Component.tsx (new)", "src/features/wallet/types/wallet.types.ts (new)", "src/store/wallet.slice.ts (new)", "src/features/wallet/index.ts (new)"]
    ,
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
        "package-lock.json",
            "repomix.config.json",
            ".git",
            ".relay",
            "node_modules",
            "bun.lock",
            "metadata.json",
            "dev-docs",
            "tsconfig.tsbuildinfo",
            //"src/store",
            "dev-docs/repomix.md"
            
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}